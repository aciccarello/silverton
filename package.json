{
  "name": "silverton",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "lint-staged": {
    "*.{js,ts,svelte,json,css,html,md,prettierrc}": "prettier --ignore-unknown --write"
  },
  "scripts": {
    "dev": "vite dev --host",
    "start": "npm run dev",
    "build": "vite build",
    "preview": "vite preview --host",
    "prepare": "svelte-kit sync || echo ''; husky",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.3",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/node": "^25.3.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.51.0",
    "svelte-check": "^4.3.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2"
  }
}
